<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fm_workorder_form_branch" model="ir.ui.view">
        <field name="name">fm.workorder.form.branch</field>
        <field name="model">fm.workorder</field>
        <field name="inherit_id" ref="fm_workorder.view_fm_workorder_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='contract_id']" position="after">
                <field name="branch_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_fm_workorder_search_branch" model="ir.ui.view">
        <field name="name">fm.workorder.search.branch</field>
        <field name="model">fm.workorder</field>
        <field name="inherit_id" ref="fm_workorder.view_fm_workorder_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='contract_id']" position="after">
                <field name="branch_id"/>
            </xpath>
            <xpath expr="//filter[@name='group_customer']" position="after">
                <filter name="group_branch" string="Branch" context="{'group_by': 'branch_id'}"/>
            </xpath>
        </field>
    </record>

</odoo>
