<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fm_contract_form_branch" model="ir.ui.view">
        <field name="name">fm.contract.form.branch</field>
        <field name="model">fm.contract</field>
        <field name="inherit_id" ref="fm_contract.view_fm_contract_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='account_manager_id']" position="after">
                <field name="branch_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_fm_contract_search_branch" model="ir.ui.view">
        <field name="name">fm.contract.search.branch</field>
        <field name="model">fm.contract</field>
        <field name="inherit_id" ref="fm_contract.view_fm_contract_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='group_am']" position="after">
                <filter name="group_branch" string="Branch" context="{'group_by': 'branch_id'}"/>
            </xpath>
        </field>
    </record>

</odoo>
