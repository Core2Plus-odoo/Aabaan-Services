<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fm_task_form_branch" model="ir.ui.view">
        <field name="name">project.task.form.branch</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="fm_fsm.view_fsm_task_form_fm"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='fm_contract_id']" position="after">
                <field name="branch_id"/>
            </xpath>
        </field>
    </record>

    <record id="view_fm_task_search_branch" model="ir.ui.view">
        <field name="name">project.task.search.branch</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="fm_fsm.view_fsm_task_search_fm"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='fm_group_contract']" position="after">
                <filter name="fm_group_branch" string="Branch" context="{'group_by': 'branch_id'}"/>
            </xpath>
        </field>
    </record>

</odoo>
