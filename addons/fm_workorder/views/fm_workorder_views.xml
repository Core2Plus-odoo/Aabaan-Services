<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fm_workorder_search" model="ir.ui.view">
        <field name="name">fm.workorder.search</field>
        <field name="model">fm.workorder</field>
        <field name="arch" type="xml">
            <search string="Work Orders">
                <field name="name" string="Reference"/>
                <field name="asset_id"/>
                <field name="customer_id"/>
                <field name="technician_id"/>
                <field name="contract_id"/>
                <separator/>
                <filter name="open" string="Open" domain="[('stage', 'not in', ('signed_off', 'cancelled'))]"/>
                <filter name="my_wo" string="My Work Orders" domain="[('technician_id.user_id', '=', uid)]"/>
                <filter name="reactive" string="Reactive" domain="[('wo_type', '=', 'reactive')]"/>
                <filter name="ppm" string="PPM" domain="[('wo_type', '=', 'ppm')]"/>
                <filter name="critical" string="P1 Critical" domain="[('severity', '=', 'p1_critical')]"/>
                <separator/>
                <filter name="group_stage" string="Stage" context="{'group_by': 'stage'}"/>
                <filter name="group_type" string="Type" context="{'group_by': 'wo_type'}"/>
                <filter name="group_severity" string="Severity" context="{'group_by': 'severity'}"/>
                <filter name="group_service_line" string="Service Line" context="{'group_by': 'service_line'}"/>
                <filter name="group_technician" string="Technician" context="{'group_by': 'technician_id'}"/>
                <filter name="group_customer" string="Customer" context="{'group_by': 'customer_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_fm_workorder_list" model="ir.ui.view">
        <field name="name">fm.workorder.list</field>
        <field name="model">fm.workorder</field>
        <field name="arch" type="xml">
            <list string="Work Orders">
                <field name="name"/>
                <field name="wo_type"/>
                <field name="asset_id"/>
                <field name="customer_id"/>
                <field name="technician_id"/>
                <field name="severity" widget="badge"
                       decoration-danger="severity == 'p1_critical'"
                       decoration-warning="severity == 'p2_high'"/>
                <field name="schedule_date_start"/>
                <field name="stage" widget="badge"
                       decoration-success="stage == 'signed_off'"
                       decoration-info="stage == 'in_progress'"
                       decoration-muted="stage == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="view_fm_workorder_kanban" model="ir.ui.view">
        <field name="name">fm.workorder.kanban</field>
        <field name="model">fm.workorder</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage" class="o_kanban_small_column">
                <field name="name"/>
                <field name="severity"/>
                <field name="stage"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <strong><field name="name"/></strong>
                                <span class="float-end"><field name="severity" widget="badge"/></span>
                            </div>
                            <div><field name="asset_id"/></div>
                            <div class="text-muted"><field name="location_id"/></div>
                            <div class="text-muted"><field name="customer_id"/></div>
                            <div class="o_kanban_record_bottom">
                                <field name="technician_id" widget="many2one_avatar_employee"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_fm_workorder_form" model="ir.ui.view">
        <field name="name">fm.workorder.form</field>
        <field name="model">fm.workorder</field>
        <field name="arch" type="xml">
            <form string="Work Order">
                <header>
                    <button name="action_assign" type="object" string="Assign" class="btn-primary" invisible="stage != 'draft'"/>
                    <button name="action_acknowledge" type="object" string="Acknowledge" class="btn-primary" invisible="stage != 'assigned'"/>
                    <button name="action_arrive" type="object" string="Arrived" invisible="stage != 'acknowledged'"/>
                    <button name="action_start" type="object" string="Start" class="btn-primary" invisible="stage not in ('arrived', 'awaiting_parts', 'awaiting_customer')"/>
                    <button name="action_complete" type="object" string="Mark Complete" class="btn-primary" invisible="stage != 'in_progress'"/>
                    <button name="action_signoff" type="object" string="Sign Off" class="btn-primary" invisible="stage != 'completed'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="stage in ('signed_off', 'cancelled')"/>
                    <field name="stage" widget="statusbar"
                           statusbar_visible="draft,assigned,acknowledged,arrived,in_progress,completed,signed_off"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Request">
                            <field name="wo_type"/>
                            <field name="severity"/>
                            <field name="asset_id"/>
                            <field name="service_line" readonly="1"/>
                            <field name="location_id" readonly="1"/>
                            <field name="customer_id"/>
                            <field name="contract_id"/>
                        </group>
                        <group string="Assignment &amp; Schedule">
                            <field name="technician_id"/>
                            <field name="reporter_id"/>
                            <field name="schedule_date_start"/>
                            <field name="schedule_date_end"/>
                            <field name="actual_start"/>
                            <field name="actual_end"/>
                            <field name="duration_minutes"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Problem &amp; Resolution" name="problem">
                            <group>
                                <field name="problem_description"/>
                                <field name="resolution_notes"/>
                                <field name="root_cause"/>
                            </group>
                        </page>
                        <page string="Checklist" name="checklist">
                            <group>
                                <field name="checklist_template_id"/>
                                <field name="checklist_progress_pct" widget="progressbar"/>
                                <field name="checklist_mandatory_complete"/>
                            </group>
                            <field name="checklist_item_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="text"/>
                                    <field name="is_mandatory"/>
                                    <field name="is_done"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                        <page string="Parts" name="parts">
                            <field name="parts_line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="description"/>
                                    <field name="qty"/>
                                    <field name="unit_cost"/>
                                    <field name="total" sum="Total"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="parts_cost_total"/>
                            </group>
                        </page>
                        <page string="Labor" name="labor">
                            <field name="labor_line_ids">
                                <list editable="bottom">
                                    <field name="technician_id"/>
                                    <field name="date"/>
                                    <field name="start_time"/>
                                    <field name="end_time"/>
                                    <field name="hours"/>
                                    <field name="hourly_rate"/>
                                    <field name="cost" sum="Cost"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="labor_hours_total"/>
                                <field name="labor_cost_total"/>
                                <field name="total_cost"/>
                            </group>
                        </page>
                        <page string="SLA" name="sla">
                            <group>
                                <field name="sla_id"/>
                                <field name="sla_response_target_min"/>
                                <field name="sla_resolution_target_min"/>
                                <field name="sla_paused"/>
                                <field name="sla_pause_minutes_total"/>
                            </group>
                        </page>
                        <page string="Sign-off" name="signoff">
                            <group>
                                <group>
                                    <field name="signed_off_by"/>
                                    <field name="signed_off_role"/>
                                    <field name="signed_off_at"/>
                                </group>
                                <group>
                                    <field name="csat_rating"/>
                                    <field name="csat_comment"/>
                                </group>
                            </group>
                            <field name="signed_off_signature" widget="image"/>
                            <separator string="Cancellation"/>
                            <field name="cancel_reason"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_fm_workorder" model="ir.actions.act_window">
        <field name="name">Work Orders</field>
        <field name="res_model">fm.workorder</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_fm_workorder_search"/>
        <field name="context">{'search_default_open': 1}</field>
    </record>

</odoo>
