<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fm_checklist_template_list" model="ir.ui.view">
        <field name="name">fm.checklist.template.list</field>
        <field name="model">fm.checklist.template</field>
        <field name="arch" type="xml">
            <list string="Checklist Templates">
                <field name="name"/>
                <field name="service_line"/>
            </list>
        </field>
    </record>

    <record id="view_fm_checklist_template_form" model="ir.ui.view">
        <field name="name">fm.checklist.template.form</field>
        <field name="model">fm.checklist.template</field>
        <field name="arch" type="xml">
            <form string="Checklist Template">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="service_line"/>
                        <field name="active"/>
                    </group>
                    <field name="item_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="text"/>
                            <field name="is_mandatory"/>
                            <field name="requires_photo"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fm_checklist_template" model="ir.actions.act_window">
        <field name="name">Checklist Templates</field>
        <field name="res_model">fm.checklist.template</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
