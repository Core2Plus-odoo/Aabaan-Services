<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add scheduling, a Generate button and a Work Orders smart button -->
    <record id="view_fm_contract_form_workorder" model="ir.ui.view">
        <field name="name">fm.contract.form.workorder</field>
        <field name="model">fm.contract</field>
        <field name="inherit_id" ref="fm_contract.view_fm_contract_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet" position="before">
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_workorders" type="object" class="oe_stat_button" icon="fa-wrench">
                        <field name="workorder_count" widget="statinfo" string="Work Orders"/>
                    </button>
                </div>
            </xpath>

            <!-- Generate button in the header -->
            <xpath expr="//header" position="inside">
                <button name="action_generate_workorders" type="object"
                        string="Generate Work Orders" class="btn-secondary"
                        invisible="state not in ('active', 'draft')"
                        confirm="This will create planned work orders for every covered asset across the contract term. Continue?"/>
            </xpath>

            <!-- Auto-scheduling criteria next to the term -->
            <xpath expr="//field[@name='renewal_term_months']" position="after">
                <field name="auto_schedule"/>
                <field name="visit_frequency"/>
                <field name="visit_hour"/>
                <field name="skip_weekends"/>
                <field name="preferred_technician_id"/>
                <field name="planned_wo_count" string="Planned visits (full term)"/>
            </xpath>

        </field>
    </record>

</odoo>
