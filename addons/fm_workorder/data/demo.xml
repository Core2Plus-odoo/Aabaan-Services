<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sample FM dataset (demo mode only). Lets a fresh install show the
         asset → contract → work-order flow without manual data entry. -->

    <!-- Customer -->
    <record id="demo_customer" model="res.partner">
        <field name="name">Marina Towers FM LLC</field>
        <field name="is_company">1</field>
    </record>

    <!-- Asset category -->
    <record id="demo_cat_chiller" model="fm.asset.category">
        <field name="name">Chillers</field>
        <field name="service_line">hvac</field>
        <field name="default_criticality">critical</field>
        <field name="default_ppm_frequency_months">3</field>
    </record>

    <!-- Location hierarchy -->
    <record id="demo_loc_site" model="fm.asset.location">
        <field name="name">Marina Tower</field>
        <field name="location_type">site</field>
    </record>
    <record id="demo_loc_building" model="fm.asset.location">
        <field name="name">Tower A</field>
        <field name="location_type">building</field>
        <field name="parent_id" ref="demo_loc_site"/>
    </record>

    <!-- Assets -->
    <record id="demo_asset_1" model="fm.asset">
        <field name="name">Chiller CH-01</field>
        <field name="category_fm_id" ref="demo_cat_chiller"/>
        <field name="location_fm_id" ref="demo_loc_building"/>
        <field name="criticality">critical</field>
        <field name="make">Carrier</field>
        <field name="model_name">30XW-1002</field>
    </record>
    <record id="demo_asset_2" model="fm.asset">
        <field name="name">Chiller CH-02</field>
        <field name="category_fm_id" ref="demo_cat_chiller"/>
        <field name="location_fm_id" ref="demo_loc_building"/>
        <field name="criticality">high</field>
        <field name="make">Carrier</field>
        <field name="model_name">30XW-1002</field>
    </record>

    <!-- Checklist template -->
    <record id="demo_ckl_chiller" model="fm.checklist.template">
        <field name="name">Quarterly Chiller Service</field>
        <field name="service_line">hvac</field>
    </record>
    <record id="demo_ckl_item_1" model="fm.checklist.template.item">
        <field name="template_id" ref="demo_ckl_chiller"/>
        <field name="sequence">10</field>
        <field name="text">Check refrigerant pressure</field>
        <field name="is_mandatory">1</field>
    </record>
    <record id="demo_ckl_item_2" model="fm.checklist.template.item">
        <field name="template_id" ref="demo_ckl_chiller"/>
        <field name="sequence">20</field>
        <field name="text">Clean condenser coils</field>
        <field name="is_mandatory">1</field>
    </record>
    <record id="demo_ckl_item_3" model="fm.checklist.template.item">
        <field name="template_id" ref="demo_ckl_chiller"/>
        <field name="sequence">30</field>
        <field name="text">Inspect electrical connections</field>
        <field name="is_mandatory">0</field>
    </record>

    <!-- Contract (auto-creates the delegated sale.order) -->
    <record id="demo_contract" model="fm.contract">
        <field name="partner_id" ref="demo_customer"/>
        <field name="contract_type">amc_comprehensive</field>
        <field name="start_date">2026-01-01</field>
        <field name="end_date">2026-12-31</field>
        <field name="acv">120000</field>
        <field name="billing_frequency">monthly</field>
        <field name="account_manager_id" ref="base.user_admin"/>
        <field name="state">active</field>
        <field name="asset_ids" eval="[(6, 0, [ref('demo_asset_1'), ref('demo_asset_2')])]"/>
    </record>
    <record id="demo_sla_p1" model="fm.sla.rule">
        <field name="contract_id" ref="demo_contract"/>
        <field name="name">P1 Critical</field>
        <field name="severity">p1_critical</field>
        <field name="response_target_minutes">30</field>
        <field name="resolution_target_minutes">240</field>
    </record>

    <!-- Work orders -->
    <record id="demo_wo_1" model="fm.workorder">
        <field name="wo_type">reactive</field>
        <field name="severity">p2_high</field>
        <field name="asset_id" ref="demo_asset_1"/>
        <field name="customer_id" ref="demo_customer"/>
        <field name="contract_id" ref="demo_contract"/>
        <field name="problem_description">Chiller CH-01 not maintaining set-point temperature.</field>
    </record>
    <record id="demo_wo_2" model="fm.workorder">
        <field name="wo_type">ppm</field>
        <field name="severity">p3_medium</field>
        <field name="asset_id" ref="demo_asset_2"/>
        <field name="customer_id" ref="demo_customer"/>
        <field name="contract_id" ref="demo_contract"/>
        <field name="checklist_template_id" ref="demo_ckl_chiller"/>
        <field name="problem_description">Quarterly preventive service for Chiller CH-02.</field>
    </record>

</odoo>
