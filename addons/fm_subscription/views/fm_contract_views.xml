<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fm_contract_form_subscription" model="ir.ui.view">
        <field name="name">fm.contract.form.subscription</field>
        <field name="model">fm.contract</field>
        <field name="inherit_id" ref="fm_contract.view_fm_contract_form"/>
        <field name="arch" type="xml">

            <!-- Start Subscription button in the header -->
            <xpath expr="//header" position="inside">
                <button name="action_start_subscription" type="object"
                        string="Start Subscription" class="btn-secondary"
                        invisible="subscription_state in ('3_progress', '5_renewed')"/>
            </xpath>

            <!-- Subscription plan/status next to commercials -->
            <xpath expr="//field[@name='billing_frequency']" position="after">
                <field name="subscription_plan_id"/>
                <field name="subscription_state"/>
            </xpath>

            <!-- Products &amp; services = the recurring lines. Shown read-only here;
                 edited on the underlying Sales Order (via the button), where
                 order_id is always set. Editing delegated order_line inline on
                 the fm.contract form creates lines with an empty order_id, which
                 crashes sale.order.line._compute_name -> _get_lang().ensure_one(). -->
            <xpath expr="//notebook" position="inside">
                <page string="Products &amp; Services" name="subscription_lines"
                      invisible="not sale_order_id">
                    <field name="sale_order_id" invisible="1"/>
                    <div class="oe_button_box" name="so_btn">
                        <button name="action_open_subscription" type="object"
                                string="Edit Products (Sales Order)" class="btn-primary"/>
                    </div>
                    <field name="order_line" readonly="1">
                        <list>
                            <field name="product_id"/>
                            <field name="name"/>
                            <field name="product_uom_qty"/>
                            <field name="price_unit"/>
                            <field name="price_subtotal"/>
                        </list>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
