<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="odoo_master_data_config_list" model="ir.ui.view">
        <field name="name">odoo.master.data.config.list</field>
        <field name="model">odoo.master.data.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="source_url"/>
                <field name="state"/>
                <field name="last_import"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="odoo_master_data_config_form" model="ir.ui.view">
        <field name="name">odoo.master.data.config.form</field>
        <field name="model">odoo.master.data.config</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="test_connection" string="Test Connection" type="object" class="btn-primary"/>
                    <button name="action_import_master_data" string="Import Master Data" type="object" class="btn-success"
                            invisible="state not in ('draft', 'configured')"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Configuration Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Source Odoo Connection">
                            <field name="source_url" placeholder="https://instance.odoo.com"/>
                            <field name="source_database" placeholder="database_name"/>
                            <field name="source_username" placeholder="admin@example.com"/>
                            <field name="source_api_key" password="True" placeholder="API Key"/>
                        </group>
                        <group string="Data to Import">
                            <field name="import_partners"/>
                            <field name="import_products"/>
                            <field name="import_employees"/>
                            <field name="import_accounts"/>
                            <field name="import_company"/>
                        </group>
                    </group>
                    <group string="Import Status">
                        <field name="state" readonly="1"/>
                        <field name="last_import" readonly="1"/>
                    </group>
                    <group string="Import Log" col="1">
                        <field name="import_log" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_odoo_master_data_config" model="ir.actions.act_window">
        <field name="name">Master Data Import</field>
        <field name="res_model">odoo.master.data.config</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create a master-data import configuration</p>
            <p>Configure the source Odoo instance credentials and select which master data
               to import (customers, products, employees, accounts).</p>
        </field>
    </record>

    <menuitem
        id="menu_odoo_master_data_import"
        name="Master Data Import"
        action="action_odoo_master_data_config"
        parent="fm_fsm.menu_fm_config_root"
        groups="base.group_system"
        sequence="70"/>
</odoo>
