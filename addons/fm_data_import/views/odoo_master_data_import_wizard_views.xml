<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard Form View -->
    <record id="odoo_master_data_import_wizard_form" model="ir.ui.view">
        <field name="name">odoo.master.data.import.wizard.form</field>
        <field name="model">odoo.master.data.import.wizard</field>
        <field name="arch" type="xml">
            <form>
                <div class="alert alert-info" role="alert">
                    <p>Imports master data from a source Odoo instance directly into this
                       database over XML-RPC. The import runs on this server, so it reaches
                       the source instance regardless of your local network.</p>
                </div>
                <sheet>
                    <div class="oe_title">
                        <h1>Import Master Data</h1>
                    </div>

                    <!-- Setup state -->
                    <group invisible="state != 'setup'">
                        <group string="Source Odoo Connection">
                            <field name="source_url" placeholder="https://your-old-instance.odoo.com"/>
                            <field name="source_database" placeholder="source_database_name"/>
                            <field name="source_username" placeholder="admin@example.com"/>
                            <field name="source_api_key" password="True" placeholder="API Key"/>
                        </group>
                        <group string="Data to Import">
                            <field name="import_partners"/>
                            <field name="import_products"/>
                            <field name="import_employees"/>
                            <field name="import_accounts"/>
                            <field name="import_company"/>
                        </group>
                    </group>

                    <!-- Done state -->
                    <group string="Import Results" col="1" invisible="state != 'done'">
                        <field name="import_log" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="test_connection" string="Test Connection" type="object"
                            class="btn-primary" invisible="state != 'setup'"/>
                    <button name="action_start_import" string="Start Import" type="object"
                            class="btn-success" invisible="state != 'setup'"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to launch the wizard -->
    <record id="action_odoo_master_data_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Master Data (Quick)</field>
        <field name="res_model">odoo.master.data.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_odoo_master_data_import_wizard"
        name="Import Master Data (Quick)"
        action="action_odoo_master_data_import_wizard"
        parent="fm_fsm.menu_fm_config_root"
        groups="base.group_system"
        sequence="71"/>
</odoo>
