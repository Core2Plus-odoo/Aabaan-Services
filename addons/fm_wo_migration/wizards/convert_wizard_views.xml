<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fm_wo_convert_wizard_form" model="ir.ui.view">
        <field name="name">fm.wo.convert.wizard.form</field>
        <field name="model">fm.wo.convert.wizard</field>
        <field name="arch" type="xml">
            <form string="Convert Legacy Work Orders">
                <div class="alert alert-info" role="alert">
                    Converts leftover <strong>fm.workorder</strong> rows into native
                    Field Service tasks (project.task) in the Facility Management
                    project. Safe to run more than once — already-converted rows are
                    skipped.
                </div>
                <field name="result_message" readonly="1" nolabel="1"
                       invisible="not result_message"/>
                <footer>
                    <button name="action_convert" type="object" string="Convert Now"
                            class="btn-primary"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_fm_wo_convert_wizard" model="ir.actions.act_window">
        <field name="name">Convert Legacy Work Orders</field>
        <field name="res_model">fm.wo.convert.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_fm_wo_convert"
              name="Convert Legacy Work Orders"
              parent="fm_fsm.menu_fm_config_root"
              action="action_fm_wo_convert_wizard"
              sequence="80"
              groups="fm_branding.group_fm_admin"/>

</odoo>
