<odoo>
    <!-- Revenue & Receivables: customer invoices/credit notes -->
    <record id="view_aabaan_ceo_revenue_pivot" model="ir.ui.view">
        <field name="name">aabaan.ceo.revenue.pivot</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="partner_id" type="row"/>
                <field name="invoice_date" type="col" interval="month"/>
                <field name="amount_untaxed_signed" type="measure"/>
                <field name="amount_total_signed" type="measure"/>
                <field name="amount_residual_signed" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_aabaan_ceo_revenue_graph" model="ir.ui.view">
        <field name="name">aabaan.ceo.revenue.graph</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <graph type="line">
                <field name="invoice_date" interval="month"/>
                <field name="amount_total_signed" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_aabaan_ceo_revenue_receivables" model="ir.actions.act_window">
        <field name="name">Revenue &amp; Receivables</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">pivot,graph,list,form</field>
        <field name="domain">[('move_type', 'in', ['out_invoice', 'out_refund']), ('state', '=', 'posted')]</field>
        <field name="help">Invoiced revenue and outstanding receivables from customer invoices, by customer and month.</field>
    </record>

    <!-- Cost & Payables: vendor bills/refunds -->
    <record id="view_aabaan_ceo_cost_pivot" model="ir.ui.view">
        <field name="name">aabaan.ceo.cost.pivot</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="partner_id" type="row"/>
                <field name="invoice_date" type="col" interval="month"/>
                <field name="amount_untaxed_signed" type="measure"/>
                <field name="amount_total_signed" type="measure"/>
                <field name="amount_residual_signed" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_aabaan_ceo_cost_graph" model="ir.ui.view">
        <field name="name">aabaan.ceo.cost.graph</field>
        <field name="model">account.move</field>
        <field name="arch" type="xml">
            <graph type="line">
                <field name="invoice_date" interval="month"/>
                <field name="amount_total_signed" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_aabaan_ceo_cost_payables" model="ir.actions.act_window">
        <field name="name">Cost &amp; Payables</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">pivot,graph,list,form</field>
        <field name="domain">[('move_type', 'in', ['in_invoice', 'in_refund']), ('state', '=', 'posted')]</field>
        <field name="help">Vendor bill cost and outstanding payables, by vendor and month.</field>
    </record>
</odoo>
