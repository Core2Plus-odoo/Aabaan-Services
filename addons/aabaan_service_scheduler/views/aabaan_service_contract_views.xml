<odoo>
    <record id="view_aabaan_service_contract_tree" model="ir.ui.view">
        <field name="name">aabaan.service.contract.tree</field>
        <field name="model">aabaan.service.contract</field>
        <field name="arch" type="xml">
            <tree decoration-danger="renewal_due" decoration-muted="state in ('expired', 'cancelled')">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="service_type"/>
                <field name="group_name"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="frequency"/>
                <field name="contract_value"/>
                <field name="next_visit_date"/>
                <field name="completed_visit_count"/>
                <field name="visit_count"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_aabaan_service_contract_form" model="ir.ui.view">
        <field name="name">aabaan.service.contract.form</field>
        <field name="model">aabaan.service.contract</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_generate_visits" type="object" string="Generate Visits" class="btn-primary"/>
                    <button name="action_activate" type="object" string="Activate"/>
                    <button name="action_cancel" type="object" string="Cancel"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,expired,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="action" name="%(action_aabaan_service_visit)d" class="oe_stat_button" icon="fa-calendar">
                            <field name="visit_count" widget="statinfo" string="Visits"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="phone"/>
                            <field name="mobile"/>
                            <field name="service_type"/>
                            <field name="product_id"/>
                            <field name="group_name"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="frequency"/>
                            <field name="custom_visit_count"/>
                            <field name="contract_value"/>
                            <field name="billing_cycle_amount"/>
                            <field name="auto_renew"/>
                            <field name="renewal_due" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="emirate"/>
                        <field name="area"/>
                        <field name="salesperson_id"/>
                        <field name="default_technician_ids" widget="many2many_tags"/>
                    </group>
                    <notebook>
                        <page string="Visits">
                            <field name="visit_ids">
                                <tree editable="bottom">
                                    <field name="planned_date"/>
                                    <field name="planned_start"/>
                                    <field name="planned_end"/>
                                    <field name="technician_ids" widget="many2many_tags"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_aabaan_service_contract_search" model="ir.ui.view">
        <field name="name">aabaan.service.contract.search</field>
        <field name="model">aabaan.service.contract</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="service_type"/>
                <field name="group_name"/>
                <filter name="active" string="Active" domain="[('state', '=', 'active')]"/>
                <filter name="renewal_due" string="Renewal Due" domain="[('renewal_due', '=', True)]"/>
                <filter name="pest_control" string="Pest Control" domain="[('service_type', '=', 'pest_control')]"/>
                <filter name="water_tank" string="Water Tank" domain="[('service_type', '=', 'water_tank')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_service" string="Service Type" context="{'group_by': 'service_type'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_emirate" string="Emirate" context="{'group_by': 'emirate'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_aabaan_service_contract" model="ir.actions.act_window">
        <field name="name">Service Contracts</field>
        <field name="res_model">aabaan.service.contract</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_aabaan_service_contract_search"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>
</odoo>
