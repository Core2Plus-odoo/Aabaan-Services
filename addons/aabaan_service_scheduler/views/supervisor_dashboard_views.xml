<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================================================================
         SUPERVISOR DASHBOARD
         Standalone app for Technician Supervisors and Sales Managers.
         Sections: Today's Operations · Approvals · Performance · Contracts
         =================================================================== -->

    <!-- ── Actions ───────────────────────────────────────────────────────── -->

    <!-- Today's Operations: Team Status (kanban grouped by technician) -->
    <record id="action_supervisor_team_today" model="ir.actions.act_window">
        <field name="name">Team Status — Today</field>
        <field name="res_model">aabaan.service.visit</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_today': 1, 'group_by': 'technician_ids'}</field>
    </record>

    <!-- Today's Operations: Scheduling Calendar -->
    <record id="action_supervisor_scheduling_calendar" model="ir.actions.act_window">
        <field name="name">Scheduling Calendar</field>
        <field name="res_model">aabaan.service.visit</field>
        <field name="view_mode">calendar,list,kanban,form</field>
    </record>

    <!-- Today's Operations: All Visits -->
    <record id="action_supervisor_all_visits" model="ir.actions.act_window">
        <field name="name">All Visits</field>
        <field name="res_model">aabaan.service.visit</field>
        <field name="view_mode">list,kanban,calendar,form</field>
    </record>

    <!-- Approvals: Pending (done, not yet approved) -->
    <record id="action_supervisor_pending_approvals" model="ir.actions.act_window">
        <field name="name">Pending Approvals</field>
        <field name="res_model">aabaan.service.visit</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'done'), ('approved', '=', False)]</field>
    </record>

    <!-- Approvals: Approved History -->
    <record id="action_supervisor_approved_history" model="ir.actions.act_window">
        <field name="name">Approved Visits</field>
        <field name="res_model">aabaan.service.visit</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('approved', '=', True)]</field>
        <field name="context">{'search_default_group_approved_date': 1}</field>
    </record>

    <!-- Performance: Technician Performance (grouped by technician) -->
    <record id="action_supervisor_technician_performance" model="ir.actions.act_window">
        <field name="name">Technician Performance</field>
        <field name="res_model">aabaan.service.visit</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="search_view_id" ref="view_aabaan_service_visit_search"/>
        <field name="context">{'search_default_group_technician': 1, 'search_default_group_state': 1}</field>
    </record>

    <!-- Performance: Visit Overview (grouped by service type / status) -->
    <record id="action_supervisor_visit_overview" model="ir.actions.act_window">
        <field name="name">Visit Overview</field>
        <field name="res_model">aabaan.service.visit</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="search_view_id" ref="view_aabaan_service_visit_search"/>
        <field name="context">{'search_default_group_service_type': 1, 'search_default_group_state': 1}</field>
    </record>

    <!-- Contracts: Active -->
    <record id="action_supervisor_active_contracts" model="ir.actions.act_window">
        <field name="name">Active Contracts</field>
        <field name="res_model">aabaan.service.contract</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'active')]</field>
    </record>

    <!-- Contracts: Expiring within 30 days -->
    <record id="action_supervisor_expiring_contracts" model="ir.actions.act_window">
        <field name="name">Expiring Contracts</field>
        <field name="res_model">aabaan.service.contract</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('state', '=', 'active'),
            ('end_date', '&lt;=', (context_today() + relativedelta(days=30)).strftime('%Y-%m-%d')),
            ('end_date', '&gt;=', context_today().strftime('%Y-%m-%d'))
        ]</field>
    </record>

    <!-- ── Root menu ─────────────────────────────────────────────────────── -->

    <menuitem
        id="menu_supervisor_dashboard_root"
        name="Supervisor"
        sequence="18"
        groups="aabaan_service_scheduler.group_aabaan_service_supervisor,sales_team.group_sale_manager"/>

    <!-- ── Today's Operations ─────────────────────────────────────────────── -->

    <menuitem
        id="menu_supervisor_operations"
        name="Today's Operations"
        parent="menu_supervisor_dashboard_root"
        sequence="10"/>

    <menuitem
        id="menu_supervisor_team_today"
        name="Team Status"
        parent="menu_supervisor_operations"
        action="action_supervisor_team_today"
        sequence="10"/>

    <menuitem
        id="menu_supervisor_scheduling_calendar"
        name="Scheduling Calendar"
        parent="menu_supervisor_operations"
        action="action_supervisor_scheduling_calendar"
        sequence="20"/>

    <menuitem
        id="menu_supervisor_all_visits"
        name="All Visits"
        parent="menu_supervisor_operations"
        action="action_supervisor_all_visits"
        sequence="30"/>

    <menuitem
        id="menu_supervisor_auto_schedule"
        name="Auto Schedule"
        parent="menu_supervisor_operations"
        action="action_aabaan_auto_schedule_wizard"
        sequence="40"/>

    <!-- ── Approvals ─────────────────────────────────────────────────────── -->

    <menuitem
        id="menu_supervisor_approvals_folder"
        name="Approvals"
        parent="menu_supervisor_dashboard_root"
        sequence="20"/>

    <menuitem
        id="menu_supervisor_pending_approvals"
        name="Pending Approvals"
        parent="menu_supervisor_approvals_folder"
        action="action_supervisor_pending_approvals"
        sequence="10"/>

    <menuitem
        id="menu_supervisor_approved_history"
        name="Approved History"
        parent="menu_supervisor_approvals_folder"
        action="action_supervisor_approved_history"
        sequence="20"/>

    <!-- ── Performance &amp; Reports ──────────────────────────────────────── -->

    <menuitem
        id="menu_supervisor_performance_folder"
        name="Performance &amp; Reports"
        parent="menu_supervisor_dashboard_root"
        sequence="30"/>

    <menuitem
        id="menu_supervisor_technician_performance"
        name="Technician Performance"
        parent="menu_supervisor_performance_folder"
        action="action_supervisor_technician_performance"
        sequence="10"/>

    <menuitem
        id="menu_supervisor_visit_overview"
        name="Visit Overview"
        parent="menu_supervisor_performance_folder"
        action="action_supervisor_visit_overview"
        sequence="20"/>

    <!-- ── Contracts ─────────────────────────────────────────────────────── -->

    <menuitem
        id="menu_supervisor_contracts_folder"
        name="Contracts"
        parent="menu_supervisor_dashboard_root"
        sequence="40"/>

    <menuitem
        id="menu_supervisor_active_contracts"
        name="Active Contracts"
        parent="menu_supervisor_contracts_folder"
        action="action_supervisor_active_contracts"
        sequence="10"/>

    <menuitem
        id="menu_supervisor_expiring_contracts"
        name="Expiring Contracts"
        parent="menu_supervisor_contracts_folder"
        action="action_supervisor_expiring_contracts"
        sequence="20"/>

</odoo>
