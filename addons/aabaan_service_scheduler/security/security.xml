<odoo>
    <record id="module_category_aabaan_service" model="ir.module.category">
        <field name="name">Service Scheduler</field>
        <field name="sequence">20</field>
    </record>

    <record id="privilege_aabaan_service_supervisor" model="res.groups.privilege">
        <field name="name">Technician Supervisor</field>
        <field name="category_id" ref="module_category_aabaan_service"/>
    </record>

    <record id="group_aabaan_service_supervisor" model="res.groups">
        <field name="name">Technician Supervisor</field>
        <field name="privilege_id" ref="privilege_aabaan_service_supervisor"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="privilege_aabaan_service_ceo" model="res.groups.privilege">
        <field name="name">Executive</field>
        <field name="category_id" ref="module_category_aabaan_service"/>
    </record>

    <record id="group_aabaan_service_ceo" model="res.groups">
        <field name="name">CEO / Executive</field>
        <field name="privilege_id" ref="privilege_aabaan_service_ceo"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>
