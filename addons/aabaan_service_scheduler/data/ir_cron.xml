<odoo>
    <record id="ir_cron_aabaan_mark_missed_visits" model="ir.cron">
        <field name="name">Aabaan: Mark Missed Service Visits</field>
        <field name="model_id" ref="model_aabaan_service_visit"/>
        <field name="state">code</field>
        <field name="code">model._cron_mark_missed_visits()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>
    <record id="ir_cron_aabaan_update_contract_states" model="ir.cron">
        <field name="name">Aabaan: Update Contract States</field>
        <field name="model_id" ref="model_aabaan_service_contract"/>
        <field name="state">code</field>
        <field name="code">model._cron_update_contract_states()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>
</odoo>
