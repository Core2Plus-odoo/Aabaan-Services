<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fm_contract_wizard_form" model="ir.ui.view">
        <field name="name">fm.contract.wizard.form</field>
        <field name="model">fm.contract.wizard</field>
        <field name="arch" type="xml">
            <form string="New Contract">
                <header>
                    <field name="step" widget="statusbar"/>
                </header>
                <sheet>

                    <!-- ============ Step 1: Customer ============ -->
                    <div invisible="step != 'customer'">
                        <h2>Who is this contract for?</h2>
                        <p class="text-muted">
                            Pick an existing customer or type a new name and choose
                            <b>Create</b>. Then name the site/building the contract covers.
                        </p>
                        <group>
                            <field name="partner_id" options="{'no_open': True}"
                                   placeholder="Type to search or create a customer..."/>
                            <field name="site_name"
                                   placeholder="e.g. ROYAL APARTMENT G+11"/>
                        </group>
                    </div>

                    <!-- ============ Step 2: Services &amp; Agreements ============ -->
                    <div invisible="step != 'service'">
                        <h2>Which services — and their agreements?</h2>
                        <p class="text-muted">
                            Tick every service the customer is taking for this site. Each
                            service gets its own agreement (contract) with the matching
                            wording — service-wise, and branch-wise where one exists.
                        </p>
                        <group>
                            <field name="service_ids" widget="many2many_checkboxes" nolabel="1"/>
                        </group>
                        <group>
                            <field name="contract_type"/>
                        </group>
                        <group string="Matched Agreements">
                            <field name="template_preview" nolabel="1" readonly="1"/>
                        </group>
                    </div>

                    <!-- ============ Step 3: Products &amp; Pricing ============ -->
                    <div invisible="step != 'products'">
                        <h2>What are we charging?</h2>
                        <p class="text-muted">
                            Add the product(s) with quantity and rate. With several
                            services ticked, set the <b>Service</b> column on each line so
                            the amount lands on the right contract. You can also skip this
                            and price the contracts later.
                        </p>
                        <field name="line_ids">
                            <list editable="bottom">
                                <field name="service_id" column_invisible="parent.contract_count_preview &lt; 2"/>
                                <field name="allowed_service_ids" column_invisible="1"/>
                                <field name="product_id"/>
                                <field name="name"/>
                                <field name="quantity"/>
                                <field name="price_unit"/>
                                <field name="price_subtotal"/>
                                <field name="currency_id" column_invisible="1"/>
                            </list>
                        </field>
                        <group class="oe_subtotal_footer">
                            <field name="amount_untaxed" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="contract_count_preview" invisible="1"/>
                        </group>
                    </div>

                    <!-- ============ Step 4: Visit Schedule ============ -->
                    <div invisible="step != 'schedule'">
                        <h2>When do we visit?</h2>
                        <p class="text-muted">
                            Each service keeps its own frequency (e.g. Pest Control monthly,
                            Water Tank Cleaning every 6 months). The visits auto-generate
                            onto the Visit Calendar and Maintenance Calendar.
                        </p>
                        <group>
                            <group string="Term">
                                <field name="start_date"/>
                                <field name="term_months"/>
                                <field name="end_date"/>
                            </group>
                            <group string="Visit Defaults">
                                <field name="auto_schedule"/>
                                <field name="visit_start_time" widget="float_time" invisible="not auto_schedule"/>
                                <field name="visit_duration_hours" widget="float_time" invisible="not auto_schedule"/>
                                <field name="skip_weekends" invisible="not auto_schedule"/>
                                <field name="preferred_technician_id" invisible="not auto_schedule"/>
                                <field name="auto_schedule_state" invisible="not auto_schedule"/>
                            </group>
                        </group>
                        <group string="Frequency per Service" invisible="not auto_schedule">
                            <field name="schedule_ids" nolabel="1">
                                <list editable="bottom" create="0" delete="0">
                                    <field name="category_id" readonly="1"/>
                                    <field name="visit_frequency"/>
                                    <field name="custom_interval_days"
                                           column_invisible="0"/>
                                </list>
                            </field>
                            <field name="planned_visit_count" readonly="1"/>
                        </group>
                    </div>

                    <!-- ============ Step 5: Review ============ -->
                    <div invisible="step != 'review'">
                        <h2>Ready to create</h2>
                        <p class="text-muted">
                            One agreement per ticked service will be created.
                            <b>Create &amp; Schedule Visits</b> activates them, generates
                            every visit plan and opens the combined calendar;
                            <b>Create as Draft</b> saves them for later.
                        </p>
                        <group>
                            <group string="Customer &amp; Services">
                                <field name="partner_id" readonly="1"/>
                                <field name="site_name" readonly="1"/>
                                <field name="service_ids" readonly="1" widget="many2many_tags"/>
                                <field name="contract_type" readonly="1"/>
                                <field name="contract_count_preview" string="Contracts to Create" readonly="1"/>
                            </group>
                            <group string="Term, Pricing &amp; Visits">
                                <field name="start_date" readonly="1"/>
                                <field name="end_date" readonly="1"/>
                                <field name="amount_untaxed" readonly="1"/>
                                <field name="planned_visit_count" readonly="1" invisible="not auto_schedule"/>
                            </group>
                        </group>
                    </div>

                </sheet>
                <footer>
                    <button name="action_back" type="object" string="Back"
                            invisible="step == 'customer'"/>
                    <button name="action_next" type="object" string="Next"
                            class="btn-primary" invisible="step == 'review'"/>
                    <button name="action_create_and_schedule" type="object"
                            string="Create &amp; Schedule Visits" class="btn-primary"
                            invisible="step != 'review'"/>
                    <button name="action_create_draft" type="object"
                            string="Create as Draft"
                            invisible="step != 'review'"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_fm_contract_wizard" model="ir.actions.act_window">
        <field name="name">New Contract (Guided)</field>
        <field name="res_model">fm.contract.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- First entry under Contracts. NOTE: parent= repeated deliberately —
         see the menuitem parent-reset gotcha in CLAUDE.md §4. -->
    <menuitem id="menu_fm_contract_wizard"
              name="New Contract (Guided)"
              parent="fm_contract.menu_fm_contracts_root"
              action="action_fm_contract_wizard"
              sequence="1"/>

</odoo>
