<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Work Orders = native FSM tasks in the Facility Management project,
         surfaced under the FM app root. -->
    <record id="action_fm_workorders" model="ir.actions.act_window">
        <field name="name">Work Orders</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">kanban,list,form,calendar,map,pivot,graph</field>
        <!-- FM work orders are exactly the FSM tasks carrying an FM work type,
             so filter on that instead of the project id: %(xmlid)d is NOT
             interpolated in an action's domain or context in this build, and
             would reach the client unparsed. The default project is baked into
             the context by the post-load write below. -->
        <field name="domain">[('fm_wo_type', '!=', False)]</field>
        <field name="context">{'fsm_mode': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Schedule your first work order</p>
            <p>Field Service tasks in the Facility Management project — reactive,
               PPM, compliance and inspection jobs, planned and dispatched with
               native Odoo Field Service.</p>
        </field>
    </record>

    <!-- Bake the resolved FM project id into the action context so new work
         orders default to the Facility Management project (context does not
         support %(xmlid)d interpolation). -->
    <function model="ir.actions.act_window" name="write"
              eval="[[ref('action_fm_workorders')],
                     {'context': &quot;{'fsm_mode': True, 'default_project_id': &quot; + str(ref('fsm_project_fm')) + '}'}]"/>

    <menuitem id="menu_fm_workorders_root"
              name="Work Orders"
              parent="fm_asset.menu_fm_root"
              sequence="5"/>

    <menuitem id="menu_fm_workorders"
              parent="menu_fm_workorders_root"
              action="action_fm_workorders"
              sequence="1"/>

    <!-- FM Configuration root (replaces the retired fm_workorder config menu). -->
    <menuitem id="menu_fm_config_root"
              name="Configuration"
              parent="fm_asset.menu_fm_root"
              sequence="99"/>

</odoo>
