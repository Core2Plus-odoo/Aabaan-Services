<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Work Orders = native FSM tasks in the Facility Management project,
         surfaced under the FM app root. -->
    <record id="action_fm_workorders" model="ir.actions.act_window">
        <field name="name">Work Orders</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">kanban,list,form,calendar,map,pivot,graph</field>
        <field name="domain">[('project_id', '=', %(fsm_project_fm)d)]</field>
        <field name="context">{
            'default_project_id': %(fsm_project_fm)d,
            'fsm_mode': True,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Schedule your first work order</p>
            <p>Field Service tasks in the Facility Management project — reactive,
               PPM, compliance and inspection jobs, planned and dispatched with
               native Odoo Field Service.</p>
        </field>
    </record>

    <menuitem id="menu_fm_workorders_root"
              name="Work Orders"
              parent="fm_asset.menu_fm_root"
              sequence="5"/>

    <menuitem id="menu_fm_workorders"
              parent="menu_fm_workorders_root"
              action="action_fm_workorders"
              sequence="1"/>

    <!-- FM Configuration root (replaces the retired fm_workorder config menu). -->
    <menuitem id="menu_fm_config_root"
              name="Configuration"
              parent="fm_asset.menu_fm_root"
              sequence="99"/>

</odoo>
