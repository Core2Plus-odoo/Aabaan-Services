<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="fm_supervisor_dashboard.Board">
        <div class="o_fm_cal">
            <!-- Header -->
            <div class="o_fm_cal_head">
                <div class="o_fm_cal_head_l">
                    <div class="o_fm_cal_logo">FM</div>
                    <div>
                        <div class="o_fm_cal_title">Maintenance Calendar</div>
                        <div class="o_fm_cal_sub" t-if="state.data"><t t-esc="state.data.company_label"/></div>
                    </div>
                </div>
                <div class="o_fm_cal_head_r" t-if="state.data">
                    <div class="o_fm_cal_nav">
                        <button class="o_fm_cal_ico" t-on-click="() => this.goMonth(state.data.prev_month)"><i class="fa fa-chevron-left"/></button>
                        <select class="o_fm_cal_sel o_fm_cal_mo" t-on-change="(ev) => this.onPeriod('month', ev)">
                            <t t-foreach="state.data.months" t-as="mo" t-key="mo.num">
                                <option t-att-value="mo.num" t-att-selected="mo.num === state.data.month_num"><t t-esc="mo.name"/></option>
                            </t>
                        </select>
                        <select class="o_fm_cal_sel o_fm_cal_yr" t-on-change="(ev) => this.onPeriod('year', ev)">
                            <t t-foreach="state.data.years" t-as="yr" t-key="yr">
                                <option t-att-value="yr" t-att-selected="yr === state.data.year"><t t-esc="yr"/></option>
                            </t>
                        </select>
                        <button class="o_fm_cal_ico" t-on-click="() => this.goMonth(state.data.next_month)"><i class="fa fa-chevron-right"/></button>
                        <button class="o_fm_cal_today" t-on-click="() => this.goMonth(state.data.this_month)">Today</button>
                        <button class="o_fm_cal_ico o_fm_noprint" t-on-click="() => this.print()" title="Print"><i class="fa fa-print"/></button>
                    </div>
                    <div class="o_fm_cal_filters">
                        <select class="o_fm_cal_sel" t-on-change="(ev) => this.onFilter('technicianId', ev)">
                            <option value="">All technicians</option>
                            <t t-foreach="state.data.technicians" t-as="u" t-key="u.id">
                                <option t-att-value="u.id" t-att-selected="u.id === state.technicianId"><t t-esc="u.name"/></option>
                            </t>
                        </select>
                        <select class="o_fm_cal_sel" t-on-change="(ev) => this.onFilter('serviceLine', ev)">
                            <option value="">All services</option>
                            <t t-foreach="state.data.service_lines" t-as="s" t-key="s.key">
                                <option t-att-value="s.key" t-att-selected="s.key === state.serviceLine"><t t-esc="s.name"/></option>
                            </t>
                        </select>
                        <select t-if="state.data.branches.length" class="o_fm_cal_sel" t-on-change="(ev) => this.onFilter('branchId', ev)">
                            <option value="">All branches</option>
                            <t t-foreach="state.data.branches" t-as="b" t-key="b.id">
                                <option t-att-value="b.id" t-att-selected="b.id === state.branchId"><t t-esc="b.name"/></option>
                            </t>
                        </select>
                    </div>
                </div>
            </div>

            <div t-if="state.loading" class="o_fm_cal_loading"><i class="fa fa-circle-o-notch fa-spin"/> Loading…</div>

            <t t-if="!state.loading and state.data">
                <!-- KPI strip -->
                <div class="o_fm_cal_kpis">
                    <div class="o_fm_cal_kpi"><span class="o_fm_cal_kv"><t t-esc="state.data.kpis.today"/></span><span class="o_fm_cal_kl">Today</span></div>
                    <div class="o_fm_cal_kpi"><span class="o_fm_cal_kv o_red"><t t-esc="state.data.kpis.overdue"/></span><span class="o_fm_cal_kl">Overdue</span></div>
                    <div class="o_fm_cal_kpi"><span class="o_fm_cal_kv o_amber"><t t-esc="state.data.kpis.unassigned"/></span><span class="o_fm_cal_kl">Unassigned</span></div>
                    <div class="o_fm_cal_kpi"><span class="o_fm_cal_kv"><t t-esc="state.data.kpis.month_total"/></span><span class="o_fm_cal_kl">This month</span></div>
                    <div class="o_fm_cal_kpi"><span class="o_fm_cal_kv o_green"><t t-esc="state.data.kpis.done"/></span><span class="o_fm_cal_kl">Done · <t t-esc="state.data.kpis.completion"/>%</span></div>
                </div>

                <div class="o_fm_cal_wrap">
                    <!-- Calendar -->
                    <div class="o_fm_cal_grid">
                        <div class="o_fm_cal_dow" t-foreach="state.data.weekdays" t-as="wd" t-key="wd_index"><t t-esc="wd"/></div>
                        <t t-foreach="state.data.weeks" t-as="week" t-key="week_index">
                            <t t-foreach="week" t-as="c" t-key="c.date">
                                <div t-attf-class="o_fm_cal_cell {{c.in_month ? '' : 'o_out'}} {{c.is_today ? 'o_today' : ''}} {{c.is_weekend ? 'o_wknd' : ''}}">
                                    <div class="o_fm_cal_num"><t t-esc="c.day"/></div>
                                    <div class="o_fm_cal_evts">
                                        <t t-foreach="c.events" t-as="e" t-key="e.id">
                                            <div t-if="e_index &lt; 3"
                                                 class="o_fm_cal_evt" t-on-click="() => this.openVisit(e.id)"
                                                 t-att-title="e.sub ? e.title + ' — ' + e.sub : e.title">
                                                <span class="o_fm_cal_tag" t-attf-style="background: {{e.color}};"><t t-esc="e.status_label"/></span>
                                                <span class="o_fm_cal_txt"><t t-esc="e.title"/></span>
                                            </div>
                                        </t>
                                        <div t-if="c.more" class="o_fm_cal_more" t-on-click="() => this.openDay(c.date)">+<t t-esc="c.more"/> more</div>
                                    </div>
                                </div>
                            </t>
                        </t>
                    </div>

                    <!-- Legend -->
                    <div class="o_fm_cal_side">
                        <div class="o_fm_cal_side_h">Legend</div>
                        <div class="o_fm_cal_leg" t-foreach="state.data.legend" t-as="lg" t-key="lg.key">
                            <span class="o_fm_cal_sw" t-attf-style="background: {{lg.color}};"/>
                            <span class="o_fm_cal_leg_l"><t t-esc="lg.label"/></span>
                            <span class="o_fm_cal_leg_c"><t t-esc="lg.count"/></span>
                        </div>
                        <div class="o_fm_cal_side_note">Click any visit to open it. Times and status are managed on the work order.</div>
                    </div>
                </div>
            </t>
        </div>
    </t>

</templates>
