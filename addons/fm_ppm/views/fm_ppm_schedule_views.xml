<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fm_ppm_schedule_list" model="ir.ui.view">
        <field name="name">fm.ppm.schedule.list</field>
        <field name="model">fm.ppm.schedule</field>
        <field name="arch" type="xml">
            <list string="PPM Schedules">
                <field name="name"/>
                <field name="asset_id"/>
                <field name="trigger_type"/>
                <field name="frequency_value"/>
                <field name="frequency_unit"/>
                <field name="next_due"/>
                <field name="auto_generate_wo"/>
                <field name="generated_wo_count" string="WOs"/>
            </list>
        </field>
    </record>

    <record id="view_fm_ppm_schedule_form" model="ir.ui.view">
        <field name="name">fm.ppm.schedule.form</field>
        <field name="model">fm.ppm.schedule</field>
        <field name="arch" type="xml">
            <form string="PPM Schedule">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Asset &amp; Checklist">
                            <field name="asset_id"/>
                            <field name="checklist_template_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Trigger">
                            <field name="trigger_type"/>
                            <field name="frequency_value"/>
                            <field name="frequency_unit"/>
                            <field name="meter_threshold" invisible="trigger_type == 'time'"/>
                            <field name="last_completed"/>
                            <field name="next_due"/>
                            <field name="auto_generate_wo"/>
                            <field name="wo_lead_days"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="generated_wo_ids">
                        <list>
                            <field name="name"/>
                            <field name="stage"/>
                            <field name="schedule_date_start"/>
                            <field name="technician_id"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fm_ppm_schedule" model="ir.actions.act_window">
        <field name="name">PPM Schedules</field>
        <field name="res_model">fm.ppm.schedule</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
