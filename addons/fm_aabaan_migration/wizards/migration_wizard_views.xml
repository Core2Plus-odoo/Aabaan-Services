<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fm_aabaan_migration_wizard_form" model="ir.ui.view">
        <field name="name">fm.aabaan.migration.wizard.form</field>
        <field name="model">fm.aabaan.migration.wizard</field>
        <field name="arch" type="xml">
            <form string="Migrate Aabaan Data to FM">
                <div class="alert alert-info" role="alert">
                    This copies aabaan contracts (and optionally their visits) into the FM Platform.
                    Each contract gets one FM "service site" asset. Customers are reused.
                    It is safe to re-run — already-migrated records are skipped.
                </div>
                <group>
                    <field name="migrate_visits"/>
                </group>
                <group invisible="not result_message">
                    <field name="result_message" nolabel="1" readonly="1"/>
                </group>
                <footer>
                    <button name="action_migrate" type="object" string="Run Migration" class="btn-primary"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_fm_aabaan_migration_wizard" model="ir.actions.act_window">
        <field name="name">Migrate Aabaan Data</field>
        <field name="res_model">fm.aabaan.migration.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_fm_aabaan_migration"
              name="Migrate Aabaan Data"
              parent="fm_fsm.menu_fm_config_root"
              action="action_fm_aabaan_migration_wizard"
              sequence="90"
              groups="fm_branding.group_fm_admin"/>

</odoo>
