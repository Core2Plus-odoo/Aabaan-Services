<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Native, JS-free FM dashboards. Standard graph/pivot actions over the
         native records — cannot fail with a client-action registry error. -->

    <!-- Operations: Field Service work orders analysis -->
    <record id="action_fm_workorder_dashboard" model="ir.actions.act_window">
        <field name="name">Operations Dashboard</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">graph,pivot,kanban,list</field>
        <field name="domain">[('fm_wo_type', '!=', False)]</field>
        <field name="context">{'group_by': ['fm_severity']}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No work orders yet</p>
            <p>Analyse Field Service work orders by service line, severity, stage and branch.</p>
        </field>
    </record>

    <!-- Commercial: contracts analysis -->
    <record id="action_fm_contract_dashboard" model="ir.actions.act_window">
        <field name="name">Contracts Dashboard</field>
        <field name="res_model">fm.contract</field>
        <field name="view_mode">graph,pivot,kanban,list</field>
        <field name="context">{'group_by': ['state']}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No contracts yet</p>
            <p>Analyse AMC / break-fix contracts by state, health and value.</p>
        </field>
    </record>

    <menuitem id="menu_fm_dashboards_root"
              name="Dashboards"
              parent="fm_asset.menu_fm_root"
              sequence="6"/>

    <menuitem id="menu_fm_workorder_dashboard"
              name="Operations Dashboard"
              parent="menu_fm_dashboards_root"
              action="action_fm_workorder_dashboard"
              sequence="10"
              groups="fm_branding.group_fm_manager"/>

    <menuitem id="menu_fm_contract_dashboard"
              name="Contracts Dashboard"
              parent="menu_fm_dashboards_root"
              action="action_fm_contract_dashboard"
              sequence="20"
              groups="fm_branding.group_fm_manager"/>

</odoo>
