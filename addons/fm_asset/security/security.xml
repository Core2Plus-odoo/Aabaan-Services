<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Multi-company isolation (brief §8.2) -->
    <record id="rule_fm_asset_company" model="ir.rule">
        <field name="name">FM Asset: multi-company</field>
        <field name="model_id" ref="model_fm_asset"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_fm_asset_location_company" model="ir.rule">
        <field name="name">FM Asset Location: multi-company</field>
        <field name="model_id" ref="model_fm_asset_location"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

</odoo>
