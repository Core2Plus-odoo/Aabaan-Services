<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fm_asset_location_list" model="ir.ui.view">
        <field name="name">fm.asset.location.list</field>
        <field name="model">fm.asset.location</field>
        <field name="arch" type="xml">
            <list string="Locations">
                <field name="full_path" string="Location"/>
                <field name="location_type"/>
                <field name="gross_area_sqm"/>
                <field name="asset_count" string="Assets"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_fm_asset_location_form" model="ir.ui.view">
        <field name="name">fm.asset.location.form</field>
        <field name="model">fm.asset.location</field>
        <field name="arch" type="xml">
            <form string="Location">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="location_type"/>
                            <field name="parent_id"/>
                            <field name="full_path" readonly="1"/>
                        </group>
                        <group>
                            <field name="gross_area_sqm"/>
                            <field name="latitude"/>
                            <field name="longitude"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fm_asset_location" model="ir.actions.act_window">
        <field name="name">Locations</field>
        <field name="res_model">fm.asset.location</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
