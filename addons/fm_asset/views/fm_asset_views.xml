<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fm_asset_search" model="ir.ui.view">
        <field name="name">fm.asset.search</field>
        <field name="model">fm.asset</field>
        <field name="arch" type="xml">
            <search string="Assets">
                <field name="name" string="Asset" filter_domain="['|', ('name', 'ilike', self), ('asset_code', 'ilike', self)]"/>
                <field name="category_fm_id"/>
                <field name="location_fm_id"/>
                <field name="serial_number"/>
                <separator/>
                <filter name="operational" string="Operational" domain="[('state', '=', 'operational')]"/>
                <filter name="under_repair" string="Under Repair" domain="[('state', '=', 'under_repair')]"/>
                <filter name="critical" string="Critical" domain="[('criticality', '=', 'critical')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_location" string="Location" context="{'group_by': 'location_fm_id'}"/>
                    <filter name="group_criticality" string="Criticality" context="{'group_by': 'criticality'}"/>
                    <filter name="group_service_line" string="Service Line" context="{'group_by': 'service_line'}"/>
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_fm_asset_list" model="ir.ui.view">
        <field name="name">fm.asset.list</field>
        <field name="model">fm.asset</field>
        <field name="arch" type="xml">
            <list string="Assets">
                <field name="asset_code"/>
                <field name="name"/>
                <field name="category_fm_id"/>
                <field name="location_full_path" string="Location"/>
                <field name="criticality" widget="badge"
                       decoration-danger="criticality == 'critical'"
                       decoration-warning="criticality == 'high'"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'operational'"
                       decoration-warning="state == 'under_repair'"
                       decoration-muted="state == 'decommissioned'"/>
                <field name="warranty_expiry" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_fm_asset_form" model="ir.ui.view">
        <field name="name">fm.asset.form</field>
        <field name="model">fm.asset</field>
        <field name="arch" type="xml">
            <form string="Asset">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Asset name"/>
                        </h1>
                        <label for="asset_code" string="Code"/>
                        <field name="asset_code"/>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="category_fm_id"/>
                            <field name="service_line" readonly="1"/>
                            <field name="location_fm_id"/>
                            <field name="criticality"/>
                            <field name="state"/>
                        </group>
                        <group string="Identity">
                            <field name="make"/>
                            <field name="model_name"/>
                            <field name="serial_number"/>
                            <field name="install_date"/>
                            <field name="warranty_expiry"/>
                            <field name="parent_asset_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Commercial">
                            <field name="currency_id" groups="base.group_multi_currency"/>
                            <field name="acquisition_cost"/>
                            <field name="manufacturer_contact_id"/>
                            <field name="service_provider_id"/>
                        </group>
                        <group string="Identification">
                            <field name="qr_code_data" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_fm_asset" model="ir.actions.act_window">
        <field name="name">Assets</field>
        <field name="res_model">fm.asset</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_fm_asset_search"/>
        <field name="context">{'search_default_group_location': 1}</field>
    </record>

</odoo>
