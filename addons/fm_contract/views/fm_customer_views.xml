<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Client onboarding: customers (companies) used on FM contracts -->
    <record id="action_fm_customer" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('is_company', '=', True)]</field>
        <field name="context">{'default_is_company': True, 'res_partner_search_mode': 'customer'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Onboard a new client</p>
            <p>Create the customer company here, then raise a contract for them under Contracts.</p>
        </field>
    </record>

</odoo>
