<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="cron_fm_sla_refresh" model="ir.cron">
        <field name="name">FM: Refresh SLA Status</field>
        <field name="model_id" ref="fm_workorder.model_fm_workorder"/>
        <field name="state">code</field>
        <field name="code">model._cron_refresh_sla()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>

    <record id="cron_fm_contract_health" model="ir.cron">
        <field name="name">FM: Compute Contract Health</field>
        <field name="model_id" ref="fm_contract.model_fm_contract"/>
        <field name="state">code</field>
        <field name="code">model._cron_compute_contract_health()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

</odoo>
